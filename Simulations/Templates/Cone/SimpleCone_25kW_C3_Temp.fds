&HEAD CHID='#CHID_Cone#',
    TITLE='Simplified cone calorimeter simulation setup'  /

 3.33333 cm cells
&MESH ID  = 'Mesh_C3',
      IJK = 9,9,20,
      XB  = -0.15,0.15, -0.15,0.15, -0.06667,0.60 /



&TIME T_END=300, WALL_INCREMENT=1, DT=1.0 /
&MISC SIMULATION_MODE = 'LES',
      TMPA            = 20.0 /

&DUMP NFRAMES=301 /



 ***** Open Vents ********************

&VENT MB='XMIN', SURF_ID='OPEN' /
&VENT MB='XMAX', SURF_ID='OPEN' /
&VENT MB='YMIN', SURF_ID='OPEN' /
&VENT MB='YMAX', SURF_ID='OPEN' /
&VENT MB='ZMIN', SURF_ID='OPEN' /
&VENT MB='ZMAX', SURF_ID='OPEN' /



***** Surfaces and Materials ********************

&SURF ID                      = 'Flux Patch A',
      COLOR                   = 'IVORY BLACK',
      EXTERNAL_FLUX           = 23.60691,
      BACKING                 = 'EXPOSED',
      THICKNESS               = 0.006, 0.03,
      MATL_ID(1,1:1)          = 'SAMPLE',
      MATL_MASS_FRACTION(1,1) = 1.0,
      MATL_ID(2,1:1)          = 'PROMATECT-LS',
      MATL_MASS_FRACTION(2,1) = 1.0 /

&SURF ID                      = 'Flux Patch B',
      COLOR                   = 'IVORY BLACK',
      EXTERNAL_FLUX           = 24.72751,
      BACKING                 = 'EXPOSED',
      THICKNESS               = 0.006, 0.03,
      MATL_ID(1,1:1)          = 'SAMPLE',
      MATL_MASS_FRACTION(1,1) = 1.0,
      MATL_ID(2,1:1)          = 'PROMATECT-LS',
      MATL_MASS_FRACTION(2,1) = 1.0 /

