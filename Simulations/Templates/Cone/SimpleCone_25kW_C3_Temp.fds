      MATL_MASS_FRACTION(2,1) = 1.0 /

&SURF ID                      = 'Flux Patch E',
      COLOR                   = 'IVORY BLACK',
      EXTERNAL_FLUX           = 25.03882,
      BACKING                 = 'EXPOSED',
      THICKNESS               = 0.006, 0.03,
      MATL_ID(1,1:1)          = 'SAMPLE',
