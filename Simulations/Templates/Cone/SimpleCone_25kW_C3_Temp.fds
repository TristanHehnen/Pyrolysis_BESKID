***** Materials ********************

# ---------------------------------------
# PROMATECT-LS Calcium silicate board 30 mm
# spec. heat: https://media.promat.com/pd36270/original/-1803860113/promatect-l_tds_en.pdf
# Rest: https://media.promat.com/doc_369086_de/original/722333084/0032405-td-promatect-ls.pdf?brand=promatconstruction&market=de
# ---------------------------------------

&MATL ID            = 'PROMATECT-LS',
      DENSITY       = 520.0,
      EMISSIVITY    = 0.9,
      CONDUCTIVITY  = 0.087,
      SPECIFIC_HEAT = 0.95 /



***** Sample ********************

# Import the sample material (MATL, SPEC, REAC)
&CATF OTHER_FILES='../SampleMaterial/MaCFP_PMMA_UMD.txt' /



***** Geometry *******************

*** Specimen ***

&VENT ID      = 'Sample Patch A',
      SURF_ID = 'Flux Patch A',
      XB =-0.05000,-0.01667,-0.05000,-0.01667,0.0,0.0 /

&VENT ID      = 'Sample Patch B',
      SURF_ID = 'Flux Patch B',
      XB =-0.05000,-0.01667,-0.01667, 0.01667,0.0,0.0 /

&VENT ID      = 'Sample Patch C',
      SURF_ID = 'Flux Patch C',
      XB =-0.05000,-0.01667, 0.01667, 0.05000,0.0,0.0 /

&VENT ID      = 'Sample Patch D',
      SURF_ID = 'Flux Patch D',
      XB =-0.01667, 0.01667,-0.05000,-0.01667,0.0,0.0 /

&VENT ID      = 'Sample Patch E',
      SURF_ID = 'Flux Patch E',
      XB =-0.01667, 0.01667,-0.01667, 0.01667,0.0,0.0 /

&VENT ID      = 'Sample Patch F',
      SURF_ID = 'Flux Patch F',
      XB =-0.01667, 0.01667, 0.01667, 0.05000,0.0,0.0 /

&VENT ID      = 'Sample Patch G',
      SURF_ID = 'Flux Patch G',
      XB = 0.01667, 0.05000,-0.05000,-0.01667,0.0,0.0 /

&VENT ID      = 'Sample Patch H',
      SURF_ID = 'Flux Patch H',
      XB = 0.01667, 0.05000,-0.01667, 0.01667,0.0,0.0 /

&VENT ID      = 'Sample Patch I',
      SURF_ID = 'Flux Patch I',
      XB = 0.01667, 0.05000, 0.01667, 0.05000,0.0,0.0 /



&OBST SURF_ID = 'INERT',
      XB      = -0.05,0.05,-0.05,0.05,-0.026,0.0 / SampleHolder



***** Analysis *******************

&DEVC ID       = 'HeatFluxGauge',
      XYZ      = 0,0,0,
      IOR      = 3,
      QUANTITY = 'GAUGE HEAT FLUX' /



&TAIL /
